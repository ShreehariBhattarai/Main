<script>
(function(){
  var tog=document.querySelector('.nav-toggle'),nl=document.querySelector('.nav-list');
  if(tog&&nl){tog.addEventListener('click',function(){nl.classList.toggle('open');tog.setAttribute('aria-expanded',nl.classList.contains('open'));});nl.querySelectorAll('a').forEach(function(a){a.addEventListener('click',function(){nl.classList.remove('open');});});}

  function animCount(el,target,suffix,dur){
    var start=performance.now();
    (function tick(now){
      var p=Math.min((now-start)/dur,1),e=1-Math.pow(1-p,3);
      el.textContent=(target*e).toFixed(suffix==='%'?1:2).replace(/\.?0+$/,'')+suffix;
      if(p<1)requestAnimationFrame(tick);
    })(start);
  }
  setTimeout(function(){
    var rev=document.getElementById('kpi-rev');
    var yoy=document.getElementById('kpi-yoy');
    var ref=document.getElementById('kpi-ref');
    if(rev)animCount(rev,4.82,'M',1200);
    if(yoy)animCount(yoy,18.2,'%',1000);
    if(ref)setTimeout(function(){if(ref)ref.textContent='0.0s';},900);
  },400);
})();

function handleSub(e){
  e.preventDefault();
  var btn=document.getElementById('sub-btn');
  btn.textContent='Subscribed ✓';btn.disabled=true;
  setTimeout(function(){btn.textContent='Subscribe';btn.disabled=false;e.target.reset();},3000);
}
</script>
